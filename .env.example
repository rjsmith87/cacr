# CACR — Cascade-Aware Confidence Routing
# Copy to .env and fill in your keys.

# Anthropic (Claude Haiku 4.5, Claude Opus 4.7)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o mini, GPT-5, o3)
OPENAI_API_KEY=

# Google Cloud project ID (used for BigQuery writes)
# BigQuery uses Application Default Credentials (ADC). Run:
#   gcloud auth application-default login \
#     --scopes="https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/bigquery"
# Your account needs: roles/bigquery.dataEditor, roles/bigquery.user,
# roles/serviceusage.serviceUsageConsumer on the project.
GCP_PROJECT=

# Google Gemini API key (gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.5-pro)
GOOGLE_API_KEY=

# BigQuery service account credentials (Render only)
# On Render: paste the full service account key JSON as a single-line string.
# Locally: leave unset and run `gcloud auth application-default login` instead;
# bq_writer.py falls back to ADC when this var is empty.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional: set to 1 for verbose debug output on stderr
# DEBUG=1
