# CACR — Cascade-Aware Confidence Routing
# Copy to .env and fill in your keys.

# Anthropic (Claude Haiku)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o mini)
OPENAI_API_KEY=

# Google Cloud project ID (used for BigQuery writes)
# BigQuery uses Application Default Credentials (ADC). Run:
#   gcloud auth application-default login \
#     --scopes="https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/bigquery"
# Your account needs: roles/bigquery.dataEditor, roles/bigquery.user,
# roles/serviceusage.serviceUsageConsumer on the project.
GCP_PROJECT=

# Google Gemini API key (gemini-2.5-flash, gemini-2.5-pro)
GOOGLE_API_KEY=

# Optional: set to 1 for verbose debug output on stderr
# DEBUG=1
